{
  "compilerOptions": {
    "target": "ES2020",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2020"],

    "outDir": "./dist",
    "rootDir": "./",

    "strict": false,
    "noImplicitAny": false,

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "skipLibCheck": true,

    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,

    "declaration": false,
    "declarationMap": false,

    "sourceMap": true
  },

  "include": [
    "src/**/*",
    "server.ts"
  ],

  "exclude": [
    "node_modules",
    "dist"
  ]
}