# Server
PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/voice2action?retryWrites=true&w=majority

# JWT
JWT_SECRET=voice2action_super_secret_jwt_key_2026_production_ready
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=voice2action_refresh_secret_key_2026_very_long_string
JWT_REFRESH_EXPIRES_IN=30d

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# Frontend URL
FRONTEND_URL=https://voice2action-civic.vercel.app

# Upload
UPLOAD_DIR=uploads/issues
MAX_FILE_SIZE=10485760

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100